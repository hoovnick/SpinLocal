# Copy this file to .env and fill in your values.
# Never commit your .env file — it contains your secret bot token.

# ── Required ──────────────────────────────────────────────────────────────────

# Your Discord bot token (from discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Absolute path to your local music folder
# Windows example: MUSIC_ROOT=C:/Users/YourName/Music
# Mac/Linux example: MUSIC_ROOT=/home/yourname/music
MUSIC_ROOT=./music

# ── Optional (these defaults work without changing them) ──────────────────────

# Discord role that can control the bot (create this role in your server)
DJ_ROLE_NAME=DJ

# Default volume, 0.0 (silent) to 1.0 (full)
DEFAULT_VOLUME=0.5

# Command prefix
COMMAND_PREFIX=!

# Where playlists are saved (relative or absolute path)
DB_PATH=./data/playlists.db
